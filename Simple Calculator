Num1=int (input("Enter your 1st Number"))
Num2=int (input("Enter your 2nd Number"))
Operator=input("Enter your Operator(+,-,*,/)")

if Operator =="+":
    Result=Num1+Num2
elif Operator =="-":
    Result=Num1-Num2
elif Operator =="*":
    Result=Num1*Num2
elif Operator== "/":
    Result=Num1/Num2
else:
    print("Invalid Operation")
print("Result:",Result)
